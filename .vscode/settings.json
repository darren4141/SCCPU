{
    "verilog.linting.iverilog.includePath": [
        "./inc",
        "./libraries",
        "./elements",
        "./tests"
    ],
    "verilog.linting.iverilog.arguments": "-I./inc -I./libraries",
    "[verilog]": {
        "editor.defaultFormatter": "chipsalliance.verible",
        "editor.formatOnSave": true
    },
    "[verilog-header]": {
        "editor.defaultFormatter": "chipsalliance.verible",
        "editor.formatOnSave": true
    },
  "npm.autoDetect": "off",
  "gulp.autoDetect": "off",
  "grunt.autoDetect": "off",
  "jake.autoDetect": "off",
  "gradle.autoDetect": "off"

}