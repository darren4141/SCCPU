{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Generate new Verilog element",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/generate_element.py",
        "${input:elementNameInput}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },      
      "problemMatcher": []
    },
    {
      "label": "Build Verilog element",
      "type": "shell",
      "command": "iverilog",
      "args": [
        "-g2012",
        "-I", "elements/inc",
        "-I", "libraries",
        "-o",
        "build/sim/elements/${input:elementNameSelect}_sim",
        "elements/src/${input:elementNameSelect}.v",
        "elements/tests/tb_${input:elementNameSelect}.v"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "Run Verilog Sim",
      "type": "shell",
      "command": "vvp",
      "args": [
        "build/sim/elements/${input:elementNameSelect}_sim"
      ],
      "dependsOn": "Build Verilog element",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Build and Run Verilog element",
      "dependsOn": "Run Verilog Sim",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build and Run All Elements",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/build_all.py"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "Generate new CPU test",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/generate_cpu_test.py",
        "${input:testNameInput}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },      
      "problemMatcher": []
    },
    {
      "label": "Assemble .s file",
      "type": "shell",
      "command": "riscv-none-elf-as",
      "args": [
        "-march=rv32i",
        "projects/programs/cpu_${input:cpuTestNameSelect}_program.s",
        "-o",
        "build/obj/cpu_${input:cpuTestNameSelect}_program.o"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },      
      "problemMatcher": []
    },
    {
      "label": "Generate .hex file from .s file",
      "type": "shell",
      "command": "riscv-none-elf-objcopy",
      "args": [
        "-O",
        "verilog",
        "build/obj/cpu_${input:cpuTestNameSelect}_program.o",
        "build/hex/cpu_${input:cpuTestNameSelect}_program.hex"
      ],
      "dependsOn": "Assemble .s file",
      "group": {
        "kind": "build",
        "isDefault": true
      },      
      "problemMatcher": []
    },
    {
      "label": "Build Verilog CPU Test",
      "type": "shell",
      "command": "iverilog",
      "args": [
        "-g2012",
        "-I", "elements/inc",
        "-I", "libraries",
        "-o",
        "build/sim/projects/$cpu_{input:cpuTestNameSelect}_sim",
        "projects/src/cpu_single_cycle.v",
        "elements/src/adder.v",
        "elements/src/alu.v",
        "elements/src/bcomp.v",
        "elements/src/control.v",
        "elements/src/dmem.v",
        "elements/src/imem.v",
        "elements/src/imm_gen.v",
        "elements/src/muxes.v",
        "elements/src/pc.v",
        "elements/src/regfile.v",
        "projects/tests/tb_cpu_${input:cpuTestNameSelect}.v"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "Run Verilog CPU Test",
      "type": "shell",
      "command": "vvp",
      "args": [
        "build/sim/projects/$cpu_{input:cpuTestNameSelect}_sim"
      ],
      "dependsOn": "Build Verilog CPU Test",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Build and Run Verilog CPU Test",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/run_cpu_test.py",
        "${input:cpuTestNameSelect}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "Build and Run All CPU Tests",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/build_all_cpu_tests.py"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    }
  ],
  "inputs": [
    {
      "id": "elementNameSelect",
      "type": "pickString",
      "description": "Choose an element",
      "options": [
        "adder",
        "alu",
        "muxes",
        "imm_gen",
        "regfile",
        "imem",
        "dmem",
        "pc",
        "bcomp",
        "control"
      ],
      "default": "alu"
    },
    {
      "id": "cpuTestNameSelect",
      "type": "pickString",
      "description": "Choose an CPU test",
      "options": [
        "add",
        "shift",
        "and",
        "or",
        "xor",
        "set",
        "store_load"
      ],
      "default": "add"
    },
    {
      "id": "elementNameInput",
      "type": "promptString",
      "description": "Enter new element name",
      "default": "alu"
    },
    {
      "id": "testNameInput",
      "type": "promptString",
      "description": "Enter new test name",
      "default": "add"
    }
  ]
}