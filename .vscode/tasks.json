{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Verilog element",
      "type": "shell",
      "command": "iverilog",
      "args": [
        "-g2012",
        "-I",
        "inc",
        "-I",
        "libraries",
        "-o",
        "build/sim/${input:elementNameSelect}_sim",
        "elements/${input:elementNameSelect}.v",
        "tests/tb_${input:elementNameSelect}.v"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "Run Verilog Sim",
      "type": "shell",
      "command": "vvp",
      "args": [
        "build/sim/${input:elementNameSelect}_sim"
      ],
      "dependsOn": "Build Verilog element",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Build and Run Verilog element",
      "dependsOn": "Run Verilog Sim",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build and Run All Elements",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/build_all.py"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "Generate new Verilog element",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/generate_element.py",
        "${input:elementNameInput}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },      
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "elementNameSelect",
      "type": "pickString",
      "description": "Choose an element",
      "options": [
        "adder",
        "alu",
        "muxes",
        "imm_gen",
        "regfile",
        "imem",
        "dmem",
        "pc",
        "bcomp",
        "control"
      ],
      "default": "alu"
    },
    {
      "id": "elementNameInput",
      "type": "promptString",
      "description": "Enter new element name",
      "default": "alu"
    }
  ]
}